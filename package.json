{
  "name": "quick-sketch",
  "version": "0.0.9",
  "private": true,
  "description": "Quick Sketch rebuilt with Electrobun and Excalidraw",
  "scripts": {
    "dev": "vite build && electrobun dev --watch",
    "dev:hmr": "concurrently \"npm run hmr\" \"npm run dev\"",
    "hmr": "vite --port 5174",
    "build": "vite build && electrobun build --env=stable",
    "typecheck": "tsc --noEmit",
    "release": "bun scripts/release.ts"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "0.18.0",
    "electrobun": "^1.14.4",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.9",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "5.1.4",
    "concurrently": "9.2.1",
    "typescript": "5.9.3",
    "vite": "7.3.1"
  }
}
